import math
import time
import random
import dsa

# ------------------------------------------------------------------ #
# Utility helpers                                                      #
# ------------------------------------------------------------------ #

def copy_int_list(src, dest, n: int):
    for i in range(n):
        dest[i] = src[i]

def tour_len(t, N: int, D) -> float:
    s: float = 0.0
    for i in range(N):
        idx1: int = t[i]
        idx2: int = t[(i + 1) % N]
        s = s + D[idx1 * N + idx2]
    return s

# ------------------------------------------------------------------ #
# 2-opt local search with don't-look bits                              #
# ------------------------------------------------------------------ #

def two_opt(t, N: int, D, dlb) -> int:
    improved: int = 1
    any_imp: int = 0

    while improved == 1:
        improved = 0
        for i in range(N):
            t1: int = t[i]
            if dlb[t1] == 1:
                continue

            i1: int = (i + 1) % N
            t2: int = t[i1]
            d12: float = D[t1 * N + t2]

            found: int = 0
            for j in range(N):
                t3: int = t[j]
                if t3 == t1 or t3 == t2:
                    continue
                j1: int = (j + 1) % N
                t4: int = t[j1]
                if t4 == t1:
                    continue

                gain: float = d12 + D[t3 * N + t4] - D[t1 * N + t3] - D[t2 * N + t4]
                if gain > 0.000001:
                    # Reverse the segment between i1 and j (or j1 and i)
                    lo: int = i1
                    hi: int = j
                    if i > j:
                        lo = j1
                        hi = i
                    while lo < hi:
                        temp: int = t[lo]
                        t[lo] = t[hi]
                        t[hi] = temp
                        lo = lo + 1
                        hi = hi - 1

                    dlb[t1] = 0
                    dlb[t2] = 0
                    dlb[t3] = 0
                    dlb[t4] = 0
                    improved = 1
                    any_imp = 1
                    found = 1
                    break

            if found == 0:
                dlb[t1] = 1

    return any_imp

# ------------------------------------------------------------------ #
# OR-opt-1: relocate a single node to a better position               #
# ------------------------------------------------------------------ #

def or_opt_1(t, N: int, D) -> int:
    any_imp: int = 0
    improved: int = 1

    while improved == 1:
        improved = 0
        for i in range(N):
            ip: int = (i - 1 + N) % N
            in_: int = (i + 1) % N
            node: int = t[i]
            prev_n: int = t[ip]
            next_n: int = t[in_]

            # Cost of removing node from current position
            remove_gain: float = D[prev_n * N + node] + D[node * N + next_n] - D[prev_n * N + next_n]

            best_gain: float = 0.000001
            best_j: int = -1

            for j in range(N):
                if j == ip or j == i or j == in_:
                    continue
                jn: int = (j + 1) % N
                if jn == i:
                    continue

                # Cost of inserting node after position j
                insert_cost: float = D[t[j] * N + node] + D[node * N + t[jn]] - D[t[j] * N + t[jn]]
                gain: float = remove_gain - insert_cost

                if gain > best_gain:
                    best_gain = gain
                    best_j = j

            if best_j < 0:
                continue

            # Perform the relocation: remove t[i], insert after t[best_j]
            saved_node: int = t[i]

            if best_j > i:
                # Shift left: [i+1 .. best_j] moves to [i .. best_j-1]
                k: int = i
                while k < best_j:
                    t[k] = t[k + 1]
                    k = k + 1
                t[best_j] = saved_node
            else:
                # Shift right: [best_j+1 .. i-1] moves to [best_j+2 .. i]
                k: int = i
                while k > best_j + 1:
                    t[k] = t[k - 1]
                    k = k - 1
                t[best_j + 1] = saved_node

            improved = 1
            any_imp = 1

    return any_imp

# ------------------------------------------------------------------ #
# Double bridge perturbation (4-opt move)                             #
# Cuts at a < b < c, reconnects: [0..a) + [c..N) + [b..c) + [a..b)  #
# ------------------------------------------------------------------ #

def double_bridge(t, N: int, tmp):
    if N < 8:
        return

    a: int = 1 + random.randint(0, N // 4 - 1)
    b: int = a + 1 + random.randint(0, N // 4 - 1)
    c: int = b + 1 + random.randint(0, N // 4 - 1)

    if c >= N:
        c = N - 1
    if b >= c:
        b = c - 1
    if a >= b:
        a = b - 1
    if a < 1:
        a = 1

    idx: int = 0
    for i in range(0, a):
        tmp[idx] = t[i]
        idx = idx + 1
    for i in range(c, N):
        tmp[idx] = t[i]
        idx = idx + 1
    for i in range(b, c):
        tmp[idx] = t[i]
        idx = idx + 1
    for i in range(a, b):
        tmp[idx] = t[i]
        idx = idx + 1

    for i in range(N):
        t[i] = tmp[i]

# ------------------------------------------------------------------ #
# Main                                                                 #
# ------------------------------------------------------------------ #

def main():
    start_time: float = time.time()

    N: int = dsa.read_int()
    if N == 1:
        dsa.write_str_ln("0.0000")
        dsa.write_int_ln(1)
        dsa.flush()
        return

    # Read coordinates into zero-overhead float arrays
    X = [0.0] * N
    Y = [0.0] * N
    for i in range(N):
        X[i] = dsa.read_float()
        Y[i] = dsa.read_float()

    # Distance matrix as flat LpFloatArray (zero LpVal overhead)
    D = [0.0] * (N * N)
    for i in range(N):
        for j in range(N):
            dx: float = X[i] - X[j]
            dy: float = Y[i] - Y[j]
            D[i * N + j] = math.sqrt(dx * dx + dy * dy)

    best_t = [0] * N
    tmp    = [0] * N
    best: float = 999999999.0

    # Greedy nearest-neighbor initialization (try all starting nodes)
    for s in range(N):
        vis = [0] * N
        tmp[0] = s
        vis[s] = 1
        cur: float = 0.0

        for i in range(1, N):
            last: int = tmp[i - 1]
            nxt: int = -1
            mn: float = 999999999.0
            for j in range(N):
                if vis[j] == 0:
                    d_val: float = D[last * N + j]
                    if d_val < mn:
                        mn = d_val
                        nxt = j
            tmp[i] = nxt
            vis[nxt] = 1
            cur = cur + mn

        cur = cur + D[tmp[N - 1] * N + tmp[0]]
        if cur < best:
            best = cur
            copy_int_list(tmp, best_t, N)

    # Initial local search on greedy tour
    t = [0] * N
    dlb = [0] * N
    copy_int_list(best_t, t, N)

    for i in range(N):
        dlb[i] = 0
    two_opt(t, N, D, dlb)
    or_opt_1(t, N, D)

    cur_len: float = tour_len(t, N, D)
    if cur_len < best:
        best = cur_len
        copy_int_list(t, best_t, N)

    # ILS: double bridge + local search
    while (time.time() - start_time) < 0.80:
        copy_int_list(best_t, t, N)
        double_bridge(t, N, tmp)

        for i in range(N):
            dlb[i] = 0
        two_opt(t, N, D, dlb)
        or_opt_1(t, N, D)

        cur_len = tour_len(t, N, D)
        if cur_len < best:
            best = cur_len
            copy_int_list(t, best_t, N)

    # Rotate so node 0 (index 0) is first
    p: int = 0
    for i in range(N):
        if best_t[i] == 0:
            p = i
            break

    final_t = [0] * N
    idx2: int = 0
    for i in range(p, N):
        final_t[idx2] = best_t[i]
        idx2 = idx2 + 1
    for i in range(0, p):
        final_t[idx2] = best_t[i]
        idx2 = idx2 + 1

    # Output
    dsa.write_float_prec(best, 4)
    dsa.writeln()
    for i in range(N):
        dsa.write_int(final_t[i] + 1)
        if i < N - 1:
            dsa.write_str(" ")
    dsa.writeln()
    dsa.flush()

main()
